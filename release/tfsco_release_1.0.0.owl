            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A coating method for applying a thin (&lt;1 μm thickness) cover to flat substrates where an excess amount of coating solution (in a volatile solvent) is placed on the substrate, which is then rotated at high speed (8000 rpm) for approximately 30 s in order to spread the solution by centripetal force. The solvent then evaporates, leaving a thin film.</obo:IAO_0000115>
        <obo:IAO_0000118 xml:lang="de">Rotationsbeschichtung</obo:IAO_0000118>
        <oboInOwl:hasExactSynonym>spin casting</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>spin-casting</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>spin-coating</oboInOwl:hasExactSynonym>
        <oboInOwl:id>CHMO:0001472</oboInOwl:id>
        <rdfs:label>spin coating</rdfs:label>
    </owl:Class>
