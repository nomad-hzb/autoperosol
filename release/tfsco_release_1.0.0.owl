        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CHMO_0001364"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A synthesis technique where a solid target is bombarded with electrons or energetic ions (e.g. Ar+) causing atoms to be ejected (&apos;sputtering&apos;). The ejected atoms then deposit, as a thin-film, on a substrate.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://orcid.org/0000-0002-0640-0422</oboInOwl:hasDbXref>
    </owl:Axiom>
    


