        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHMO_0001314"/>
        <obo:IAO_0000115>A synthesis method where the substrate is exposed to volatile precursors (one of which is an organometallic compound) which react or decompose on the surface to produce a deposit.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>MOCVD</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>OMCVD</oboInOwl:hasExactSynonym>
