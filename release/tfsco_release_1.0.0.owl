    <!-- http://purl.obolibrary.org/obo/PATO_0000921 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000921">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0001708"/>
        <obo:IAO_0000115>A 1-D extent quality which is equal to the distance from one side of an object to another side which is opposite.</obo:IAO_0000115>
        <pato:seeAlso>https://github.com/pato-ontology/pato/issues/337</pato:seeAlso>
        <oboInOwl:hasOBONamespace>quality</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>breadth</oboInOwl:hasRelatedSynonym>
