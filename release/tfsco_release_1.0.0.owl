        <obo:IAO_0000600 xml:lang="en">a wet chemical deposition method, which deposits a liquid precursor (ink) onto a substrate by jetting it through a print head.</obo:IAO_0000600>
        <rdfs:label xml:lang="en">ink jet printing</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002054 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002054">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000118 xml:lang="de">Tiefdruck</obo:IAO_0000118>
        <obo:IAO_0000118 xml:lang="en">a wet chemical deposition which prints an ink onto a substrate via a image carrier. The image carrier (often a cylinder) comes in direct contact with the substrate.</obo:IAO_0000118>
        <oboInOwl:hasExactSynonym xml:lang="en">Rotogravure</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">Gravure printing</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002055 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002055">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000115 xml:lang="en">a wet chemical deposition which deposits an ink onto a substrate via a image carrier. The image carrier (often a cylinder) does not come into direct contact with the substrate.</obo:IAO_0000115>
        <obo:IAO_0000118 xml:lang="de">Offsetdruck</obo:IAO_0000118>
        <rdfs:label xml:lang="en">Offset printing</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002056 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002056">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000115 xml:lang="en">a wet chemical deposition which deposits an ink onto a substrate via a image carrier. The image carrier (usually a mesh) does come into direct contact with the substrate.</obo:IAO_0000115>
        <obo:IAO_0000118 xml:lang="de">Siebdruck</obo:IAO_0000118>
        <rdfs:label xml:lang="en">Screen printing</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002057 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002057">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000115 xml:lang="en">a wet chemical deposition method, which deposits a  vapourized precursor onto a substrate by jetting it through a print head.</obo:IAO_0000115>
        <obo:IAO_0000118 xml:lang="de">Aerosol Jet Druck</obo:IAO_0000118>
        <obo:IAO_0000118 xml:lang="en">Aerosol jet printing</obo:IAO_0000118>
        <rdfs:label xml:lang="en">Aerosol printing</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002058 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002058">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000140"/>
        <rdfs:comment xml:lang="en">is a setting datum, which indicates the settings for the scan rate</rdfs:comment>
        <rdfs:label xml:lang="en">scan rate setting datum</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002059 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002059">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000115 xml:lang="en">a wet chemical deposition in which a layer is deposited onto a substrate by dropping liquid drops, that contain the dissolved chemical of interest</obo:IAO_0000115>
        <rdfs:label xml:lang="en">Drop casting</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002060 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002060">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000118 xml:lang="en">Doctor blading</obo:IAO_0000118>
        <obo:IAO_0000118 xml:lang="de">Rakelbeschichtung</obo:IAO_0000118>
        <obo:IAO_0000600 xml:lang="en">a small amount of solution is placed on a substrate and spread evenly using a doctor blade. The substrate is then dried to form a thin film.</obo:IAO_0000600>
        <rdfs:label xml:lang="en">Blade coating</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002061 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002061">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000118 xml:lang="en">EPD</obo:IAO_0000118>
        <obo:IAO_0000118 xml:lang="de">Elektrophoretische Abscheidung</obo:IAO_0000118>
        <obo:IAO_0000600 xml:lang="en">a substrate is immersed in a solution containing a salt of the material to be deposited and an electric current is passed through the solution, which causes the material to be deposited on the substrate as a thin film.</obo:IAO_0000600>
        <rdfs:label xml:lang="en">Electrophoretic deposition</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.archive.org/tfsco/TFSCO_00002062 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00002062">
        <rdfs:subClassOf rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002051"/>
        <obo:IAO_0000118 xml:lang="de">Sol-Gel-Prozess</obo:IAO_0000118>
        <obo:IAO_0000600 xml:lang="en">a solution containing precursor materials is formed, which is then deposited onto a substrate and dried to form a thin film. This process can be used to deposit a wide range of materials, including ceramics, metals and polymers.</obo:IAO_0000600>
        <rdfs:label xml:lang="en">Sol-gel deposition</rdfs:label>
    </owl:Class>
    


