            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000118 xml:lang="de">Elektrische Stromdichte</obo:IAO_0000118>
        <obo:IAO_0000600 xml:lang="en">is a measure of the density of flow of electric charge; it is the electric current per unit area of cross section.</obo:IAO_0000600>
