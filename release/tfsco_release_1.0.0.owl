    <!-- http://purl.obolibrary.org/obo/PATO_0000044 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000044">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0050000"/>
        <obo:IAO_0000115>A physical quality which inheres in a bearer by virtue of the number of the bearer&apos;s repetitive actions in a particular time.</obo:IAO_0000115>
