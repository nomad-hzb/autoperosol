        <obo:IAO_0000115 xml:lang="en">Is a innermaterial process in which a bound electron is pushed to a higher energy level without removing it from the atomic shell</obo:IAO_0000115>
        <om-2:alternativeLabel xml:lang="de">Elektronenanregung</om-2:alternativeLabel>
        <rdfs:label xml:lang="en">Electron excitation</rdfs:label>
    </owl:Class>
    


