    <!-- https://purl.archive.org/tfsco/TFSCO_00000063 -->

    <owl:Class rdf:about="https://purl.archive.org/tfsco/TFSCO_00000063">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0001018"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000417"/>
                <owl:someValuesFrom rdf:resource="https://purl.archive.org/tfsco/TFSCO_00002098"/>
