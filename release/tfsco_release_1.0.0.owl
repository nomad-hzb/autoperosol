        <oboInOwl:hasExactSynonym>metalorganic CVD</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>metalorganic chemical vapor deposition</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>metalorganic chemical vapour deposition</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>organometallic chemical vapor deposition</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>organometallic chemical vapour deposition</oboInOwl:hasExactSynonym>
        <oboInOwl:id>CHMO:0001324</oboInOwl:id>
