    <!-- http://purl.obolibrary.org/obo/PATO_0000051 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000051">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0001241"/>
        <obo:IAO_0000111>morphology</obo:IAO_0000111>
        <obo:IAO_0000115>A quality of a single physical entity inhering in the bearer by virtue of the bearer&apos;s size or shape or structure.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/pato.owl"/>
        <rdfs:label>morphology</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000052 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000052">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0000051"/>
        <obo:IAO_0000115>A morphological quality inhering in a bearer by virtue of the bearer&apos;s ratios of distances between its features (points, edges, surfaces and also holes etc).</obo:IAO_0000115>
        <oboInOwl:hasAlternativeId>PATO:0001647</oboInOwl:hasAlternativeId>
        <oboInOwl:hasExactSynonym>relational shape quality</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>quality</oboInOwl:hasOBONamespace>
        <oboInOwl:id>PATO:0000052</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#attribute_slim"/>
        <rdfs:comment>Shapes are invariant on size transformations. Shapes can be subdivided into 2D and 3D shapes, We can also make a distinction between shapes of complete self-connected objects, and shapes of parts of objects.</rdfs:comment>
        <rdfs:label>shape</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PATO_0000052"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A morphological quality inhering in a bearer by virtue of the bearer&apos;s ratios of distances between its features (points, edges, surfaces and also holes etc).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>PATOC:GVG</oboInOwl:hasDbXref>
    </owl:Axiom>
    


